generator client {
  provider   = "prisma-client-js"
  output     = "../src/infrastructure/prisma/client"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum StudyType {
  CAREER
  COURSE
  CERTIFICATION
  OTHER
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password_hash String
  name          String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  avatarId      String?      @default("avatar_1")
  task          Task[]
  category      Category[]
  career        Career[]
  enrollments   Enrollment[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid())
  name      String
  color     String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  task      Task[]
  createdAt DateTime @default(now())

  @@unique([id, userId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("PENDING")
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  @@unique([id, userId])
}

model Career {
  id                 String    @id @default(uuid())
  name               String
  institution        String?
  type               StudyType @default(CAREER)
  whatsappGroup      String?
  facultyContactInfo String?
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  subjects           Subject[]
}

model Subject {
  id           String               @id @default(uuid())
  careerId     String
  career       Career               @relation(fields: [careerId], references: [id])
  name         String
  yearLevel    Int
  semester     Int
  credits      Int                  @default(0)
  enrollments  Enrollment[]
  correlatives SubjectCorrelative[] @relation("SubjectToCorrelative")
  requiredBy   SubjectCorrelative[] @relation("CorrelativeToSubject")
}

model SubjectCorrelative {
  id                String  @id @default(uuid())
  subjectId         String
  subject           Subject @relation("SubjectToCorrelative", fields: [subjectId], references: [id])
  requiredSubjectId String
  requiredSubject   Subject @relation("CorrelativeToSubject", fields: [requiredSubjectId], references: [id])
  type              String

  @@unique([subjectId, requiredSubjectId])
}

model Enrollment {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  status       String
  finalGrade   Float?
  academicYear Int
  createdAt    DateTime @default(now())

  schedules   Schedule[]
  contacts    Contact[]
  evaluations AcademicEvaluation[]
  resources   Resource[]

  @@unique([id, userId])
  @@unique([userId, subjectId])
}

model Schedule {
  id           String     @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  dayOfWeek    Int
  startTime    String
  endTime      String
  type         String
  location     String?

  @@unique([enrollmentId, dayOfWeek, startTime])
  @@map("class_schedules")
}

model AcademicEvaluation {
  id           String     @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  type         String
  date         DateTime
  topics       String?
  grade        Float?
  status       String
  reflection   String?

  @@map("academic_evaluations")
}

model Contact {
  id           String     @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  name         String
  role         String
  email        String?
  phone        String?
  whatsappLink String?
  notes        String?
}

model Resource {
  id           String     @id @default(uuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  name         String
  url          String?
  type         String
  isRead       Boolean    @default(false)
}
